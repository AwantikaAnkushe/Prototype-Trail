{
    "manifest_version": 3,
    "name": "IssueGuard - LLM Data Leakage Preventer",
    "version": "1.0",
    "description": "Prevents sensitive data from being sent to LLMs at the browser level.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "matcher.js",
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}